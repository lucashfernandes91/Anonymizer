</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Adicionar se não existir:</span><span>
</span></span><span><span>STATIC_URL </span><span class="token token" style="color: rgb(234, 236, 240);">=</span><span> </span><span class="token token" style="color: rgb(155, 233, 99);">'/static/'</span><span>
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Para produção (collectstatic):</span><span>
</span></span><span><span>STATIC_ROOT </span><span class="token token" style="color: rgb(234, 236, 240);">=</span><span> BASE_DIR </span><span class="token token" style="color: rgb(234, 236, 240);">/</span><span> </span><span class="token token" style="color: rgb(155, 233, 99);">'staticfiles'</span></span></code></pre></div></div>
