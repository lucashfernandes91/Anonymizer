</span></span><span>from django.shortcuts import render
</span><span>from django.core.files.uploadedfile import InMemoryUploadedFile
</span><span>from .services import anonimizar_imagem, obter_endereco, extrair_classificar_metadados
</span><span>from .models import EstatisticaGlobal, AcessoUnico
</span><span>
</span><span>
</span><span>def registrar_acesso(request):
</span><span>    """
</span><span>    Chame isso no início de qualquer view pública.
</span><span>    Usa a session_key do Django para garantir unicidade.
</span><span>    """
</span><span>    # Garante que existe uma sessão ativa
</span><span>    if not request.session.session_key:
</span><span>        request.session.create()
</span><span>
</span><span>    session_key = request.session.session_key
</span><span>
</span><span>    # Tenta registrar — se já existe, ignora (unique constraint)
</span><span>    AcessoUnico.objects.get_or_create(
</span><span>        session_key=session_key,
</span><span>        defaults={
</span><span>            'ip': _get_ip(request),
</span><span>            'user_agent': request.META.get('HTTP_USER_AGENT', '')[:500],
</span><span>        }
</span><span>    )
</span><span>
</span><span>
</span><span>def _get_ip(request):
</span><span>    """Pega o IP real mesmo atrás de proxy/load balancer."""
</span><span>    x_forwarded = request.META.get('HTTP_X_FORWARDED_FOR')
</span><span>    if x_forwarded:
</span><span>        return x_forwarded.split(',')[0].strip()
</span><span>    return request.META.get('REMOTE_ADDR')
</span><span>
</span><span>
</span><span>def home(request):
</span><span>    # Registra acesso único
</span><span>    registrar_acesso(request)
</span><span>
</span><span>    context = {
</span><span>        'total_imagens': EstatisticaGlobal.total(),
</span><span>        'total_acessos': AcessoUnico.total(),
</span><span>    }
</span><span>
</span><span>    if request.method == "POST":
</span><span>        image = request.FILES.get("image")
</span><span>
</span><span>        if image:
</span><span>            # garante leitura correta
</span><span>            image.seek(0)
</span><span>
</span><span>            nova_imagem, exif, gps, lat, lon = anonimizar_imagem(image)
</span><span>
</span><span>            EstatisticaGlobal.incrementar()
</span><span>
</span><span>            # garante tipo correto
</span><span>            lat = float(lat) if lat is not None else None
</span><span>            lon = float(lon) if lon is not None else None
</span><span>
</span><span>            # reverse geocoding
</span><span>            endereco = None
</span><span>            if lat is not None and lon is not None:
</span><span>                endereco = obter_endereco(lat, lon)
</span><span>
</span><span>                # imagem original
</span><span>                image.seek(0)
</span><span>                original_bytes = image.read()
</span><span>                original_b64 = base64.b64encode(original_bytes).decode()
</span><span>
</span><span>                # imagem anonimizada
</span><span>                anon_bytes = nova_imagem.getvalue()
</span><span>                anon_b64 = base64.b64encode(anon_bytes).decode()
</span><span>
</span><span>                # metadados ordenados por criticidade
</span><span>                image.seek(0)
</span><span>                metadados = extrair_classificar_metadados(image)
</span><span>
</span><span>                context = {
</span><span>                    "original": original_b64,
</span><span>                    "anon": anon_b64,
</span><span>                    "exif": exif,
</span><span>                    "gps": gps,
</span><span>                    "lat": lat,
</span><span>                    "lon": lon,
</span><span>                    "endereco": endereco,
</span><span>                    "metadados": metadados,
</span><span>                    "total_imagens": EstatisticaGlobal.total(),
</span><span>                    "total_acessos": AcessoUnico.total(),
</span><span>                }
</span><span>
</span><span>    return render(request, "home.html", context)
</span><span>
</span><span>atualize a view acima com 
</span><span>def sanitizar_exif(exif_dict):
</span><span>    resultado = {}
</span><span>    for key, value in exif_dict.items():
</span><span>        val_str = str(value)
</span><span>        # Remove se for dado binário (muitos \x)
</span><span>        if val_str.count('\\x') &gt; 5:
</span><span>            continue
</span><span>        # Trunca valores muito longos
</span><span>        if len(val_str) &gt; 200:
</span><span>            val_str = val_str[:200] + '...'
</span><span>        resultado[key] = val_str
</span><span>    return resultado</span></code></pre></div></div><div class="absolute bottom-0 left-0 right-0 h-12 bg-gradient-to-t from-bg-300 to-transparent pointer-events-none"></div></div><button class="pb-3 pt-1 text-xs text-text-500/80 hover:text-text-100 transition w-3/4 text-left rounded-lg">Mostrar mais</button></div></div></div><div class="flex justify-start opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition" role="group" aria-label="Message actions"><div class="text-text-300"><div class="text-text-300 flex items-stretch justify-between"><span class="text-text-500 text-xs flex items-center mr-2" data-state="closed">15:26</span><div class="flex items-center"><div class="w-fit" data-state="closed"><button class="inline-flex
