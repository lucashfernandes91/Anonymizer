</span></span><span><span>                </span><span class="token token" style="color: rgb(155, 233, 99);">"anon"</span><span class="token token" style="color: rgb(211, 215, 222);">:</span><span> anon_b64</span><span class="token token" style="color: rgb(211, 215, 222);">,</span><span>
</span></span><span><span>                </span><span class="token token" style="color: rgb(155, 233, 99);">"exif"</span><span class="token token" style="color: rgb(211, 215, 222);">:</span><span> sanitizar_exif</span><span class="token token" style="color: rgb(211, 215, 222);">(</span><span>exif</span><span class="token token" style="color: rgb(211, 215, 222);">)</span><span> </span><span class="token token" style="color: rgb(204, 123, 244);">if</span><span> exif </span><span class="token token" style="color: rgb(204, 123, 244);">else</span><span> </span><span class="token token" style="color: rgb(211, 215, 222);">{</span><span class="token token" style="color: rgb(211, 215, 222);">}</span><span class="token token" style="color: rgb(211, 215, 222);">,</span><span>
</span></span><span><span>                </span><span class="token token" style="color: rgb(155, 233, 99);">"gps"</span><span class="token token" style="color: rgb(211, 215, 222);">:</span><span> gps</span><span class="token token" style="color: rgb(211, 215, 222);">,</span><span>
</span></span><span><span>                </span><span class="token token" style="color: rgb(155, 233, 99);">"lat"</span><span class="token token" style="color: rgb(211, 215, 222);">:</span><span> lat</span><span class="token token" style="color: rgb(211, 215, 222);">,</span><span>
