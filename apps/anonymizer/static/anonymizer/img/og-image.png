</span></span><span><span>        </span><span class="token token" style="color: rgb(129, 136, 152);"># Remove se for dado binário (muitos \x)</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(204, 123, 244);">if</span><span> val_str</span><span class="token token" style="color: rgb(211, 215, 222);">.</span><span>count</span><span class="token token" style="color: rgb(211, 215, 222);">(</span><span class="token token" style="color: rgb(155, 233, 99);">'\\x'</span><span class="token token" style="color: rgb(211, 215, 222);">)</span><span> </span><span class="token token" style="color: rgb(234, 236, 240);">&gt;</span><span> </span><span class="token token" style="color: rgb(94, 237, 237);">5</span><span class="token token" style="color: rgb(211, 215, 222);">:</span><span>
</span></span><span><span>            </span><span class="token token" style="color: rgb(204, 123, 244);">continue</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(129, 136, 152);"># Trunca valores muito longos</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(204, 123, 244);">if</span><span> </span><span class="token token" style="color: rgb(251, 173, 96);">len</span><span class="token token" style="color: rgb(211, 215, 222);">(</span><span>val_str</span><span class="token token" style="color: rgb(211, 215, 222);">)</span><span> </span><span class="token token" style="color: rgb(234, 236, 240);">&gt;</span><span> </span><span class="token token" style="color: rgb(94, 237, 237);">200</span><span class="token token" style="color: rgb(211, 215, 222);">:</span><span>
