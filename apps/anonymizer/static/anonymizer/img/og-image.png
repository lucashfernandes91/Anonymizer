;">(</span><span class="token token" style="color: rgb(155, 233, 99);">'robots.txt'</span><span class="token token" style="color: rgb(211, 215, 222);">,</span><span> TemplateView</span><span class="token token" style="color: rgb(211, 215, 222);">.</span><span>as_view</span><span class="token token" style="color: rgb(211, 215, 222);">(</span><span>
